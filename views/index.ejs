<!DOCTYPE html>
<html>
<% include header.ejs %>

<body style="margin:0; font-family: 'Segoe UI', sans-serif; background: linear-gradient(135deg, #f8e1e7 0%, #fce4ec 100%); min-height:100vh; display:flex; align-items:center; justify-content:center;">

  <div style="background:white; border-radius:16px; padding:40px; width:100%; max-width:400px; box-shadow: 0 8px 32px rgba(0,0,0,0.1);">
    
    <!-- Logo -->
    <div style="text-align:center; margin-bottom:30px;">
      <div style="font-size:40px;">💅</div>
      <h1 style="color:#c2185b; font-size:24px; margin:8px 0 4px;">Glow Beauty Salon</h1>
      <p style="color:#999; font-size:13px; margin:0;">Sign in to your account</p>
    </div>

    <!-- Error message -->
    <p style="color:red; text-align:center; font-size:13px;"><%=message %></p>

    <!-- Login Form -->
    <form action="/?default=English" method="post">
      
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; color:#555; display:block; margin-bottom:6px;">Email</label>
        <input type="email" name="username" placeholder="Enter your email"
          style="width:100%; padding:10px 14px; border:1px solid #e0e0e0; border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;">
      </div>

      <div style="margin-bottom:24px;">
        <label style="font-size:13px; color:#555; display:block; margin-bottom:6px;">Password</label>
        <input type="password" name="password" placeholder="Enter your password"
          style="width:100%; padding:10px 14px; border:1px solid #e0e0e0; border-radius:8px; font-size:14px; outline:none; box-sizing:border-box;">
      </div>

      <button type="submit"
        style="width:100%; padding:12px; background:#c2185b; color:white; border:none; border-radius:8px; font-size:15px; font-weight:600; cursor:pointer;">
        Sign In
      </button>

    </form>

    <div style="text-align:center; margin-top:20px;">
      <a href="/register" style="color:#c2185b; font-size:13px; text-decoration:none;">Don't have an account? Register here</a>
    </div>

  </div>

</body>
</html>